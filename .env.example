# Client-safe (Nuxt runtimeConfig.public — safe to expose in the static bundle)
NUXT_PUBLIC_NEON_DATA_API_URL=https://ep-dark-meadow-atpy3tcm.apirest.c-9.us-east-1.aws.neon.tech/neondb/rest/v1
# Relative, same-origin — proxied to the real Neon Auth host by
# functions/auth/[[path]].ts in production and by nuxt.config.ts's Vite dev
# proxy locally, so the session cookie is first-party (required for it to
# persist in the iOS WebClip; a direct cross-origin URL here breaks that).
NUXT_PUBLIC_NEON_AUTH_URL=/auth
NUXT_PUBLIC_R2_PUBLIC_URL=https://image.myolfactorylab.com
NUXT_PUBLIC_UPLOAD_ENDPOINT=/api/photos

# Dev-only — drizzle-kit migrations only, never shipped to the client
DATABASE_URL=
